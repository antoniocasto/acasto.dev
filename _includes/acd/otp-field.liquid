{%- assign field_state = include.state | default: 'normal' -%}
{%- assign field_length = include.length | default: 6 -%}
{%- assign is_disabled = include.disabled == true or include.disabled == 'true' or field_state == 'disabled' -%}
{%- assign wrapper_id = include.id | default: '' -%}
{%- assign control_id = include.input_id | default: '' -%}
{%- assign field_name = include.name | default: '' | strip -%}
{%- if control_id == '' and wrapper_id != '' -%}
  {%- assign control_id = wrapper_id | append: '-input' -%}
{%- elsif control_id == '' and field_name != '' -%}
  {%- assign control_id = field_name | slugify | append: '-input' -%}
{%- endif -%}
{%- assign inputmode = include.inputmode | default: 'numeric' -%}
{%- assign autocomplete = include.autocomplete | default: 'one-time-code' -%}
{%- assign message_id = '' -%}
{%- if control_id != '' -%}
  {%- capture message_id -%}{{ control_id }}-help{%- endcapture -%}
{%- elsif wrapper_id != '' -%}
  {%- capture message_id -%}{{ wrapper_id }}-help{%- endcapture -%}
{%- endif -%}
{%- capture describedby -%}
  {%- if include.describedby -%}
    {{ include.describedby }}
  {%- elsif include.message_text or include.message_html -%}
    {{ message_id }}
  {%- endif -%}
{%- endcapture -%}
<div
  class="{% include acd/_internal/class-name.liquid base='ac-otp-field' extra=include.class %}"
  {%- include acd/_internal/attribute.liquid name='id' value=wrapper_id -%}
  data-ac-state="{{ field_state | escape }}"
  data-ac-length="{{ field_length | escape }}"
  {%- if include.attrs %} {{ include.attrs | strip }}{%- endif -%}
>
  {%- if include.label -%}
    <label class="ac-otp-field__label"{% if control_id != '' %} for="{{ control_id | escape }}"{% endif %}>{{ include.label | escape }}</label>
  {%- endif -%}
  <div class="ac-otp-field__control">
    <div class="ac-otp-field__slots" style="--ac-otp-length: {{ field_length }};">
      {%- for index in (1..field_length) -%}
        <span class="ac-otp-field__slot" aria-hidden="true"></span>
      {%- endfor -%}
    </div>
    <input
      class="ac-otp-field__input"
      type="text"
      {%- include acd/_internal/attribute.liquid name='id' value=control_id -%}
      {%- include acd/_internal/attribute.liquid name='name' value=include.name -%}
      {%- include acd/_internal/attribute.liquid name='value' value=include.value -%}
      {%- include acd/_internal/attribute.liquid name='inputmode' value=inputmode -%}
      {%- include acd/_internal/attribute.liquid name='autocomplete' value=autocomplete -%}
      {%- include acd/_internal/attribute.liquid name='maxlength' value=field_length -%}
      {%- if field_state == 'error' -%} aria-invalid="true"{%- endif -%}
      {%- if describedby != '' -%} aria-describedby="{{ describedby | strip | escape }}"{%- endif -%}
      {%- if is_disabled -%} disabled{%- endif -%}
    />
  </div>
  {%- if include.message_text or include.message_html -%}
    <p
      class="ac-field-message"
      {%- include acd/_internal/attribute.liquid name='id' value=message_id -%}
      {%- include acd/_internal/data-attr.liquid name='data-ac-tone' value=include.message_tone -%}
    >
      {%- if include.message_html -%}{{ include.message_html }}{%- else -%}{{ include.message_text | escape }}{%- endif -%}
    </p>
  {%- endif -%}
</div>
