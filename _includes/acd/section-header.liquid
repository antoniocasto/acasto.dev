{%- assign heading_tag = include.heading_tag | default: 'h2' -%}
{%- assign component_size = include['size'] -%}
<header
  class="{% include acd/_internal/class-name.liquid base='ac-section-header' extra=include.class %}"
  {%- include acd/_internal/attribute.liquid name='id' value=include.id -%}
  {%- include acd/_internal/data-attr.liquid name='data-ac-size' value=component_size -%}
  {%- include acd/_internal/data-attr.liquid name='data-ac-style' value=include.style -%}
  {%- if include.attrs %} {{ include.attrs | strip }}{%- endif -%}
>
  <div class="ac-section-header__main">
    <div class="ac-section-header__heading-group">
      <{{ heading_tag }} class="ac-section-header__title">{{ include.title | escape }}</{{ heading_tag }}>
      {%- if include.subtitle -%}
        <p class="ac-section-header__subtitle">{{ include.subtitle | escape }}</p>
      {%- endif -%}
    </div>
    {%- if include.action_html -%}
      <div class="ac-section-header__action">{{ include.action_html }}</div>
    {%- endif -%}
  </div>
</header>
