{%- assign element = include.element | default: 'div' -%}
{%- assign is_button = include.button == true or include.button == 'true' -%}
{%- if include.href and include.href != '' -%}
  {%- assign element = 'a' -%}
{%- elsif is_button -%}
  {%- assign element = 'button' -%}
{%- endif -%}
<{{ element }}
  class="{% include acd/_internal/class-name.liquid base='ac-list-row' extra=include.class %}"
  {%- include acd/_internal/attribute.liquid name='id' value=include.id -%}
  {%- if element == 'a' -%} href="{{ include.href | escape }}"{%- endif -%}
  {%- if element == 'button' -%} type="{{ include.type | default: 'button' | escape }}"{%- endif -%}
  {%- if include.divider == false or include.divider == 'false' -%} data-ac-divider="false"{%- endif -%}
  {%- if include.attrs %} {{ include.attrs | strip }}{%- endif -%}
>
  {%- if include.leading_html -%}
    <span class="ac-list-row__leading" aria-hidden="true">{{ include.leading_html }}</span>
  {%- endif -%}
  <span class="ac-list-row__body">
    <span class="ac-list-row__title">{{ include.title | escape }}</span>
    {%- if include.subtitle -%}
      <span class="ac-list-row__subtitle">{{ include.subtitle | escape }}</span>
    {%- endif -%}
  </span>
  {%- if include.trailing_html -%}
    <span class="ac-list-row__trailing" aria-hidden="true">{{ include.trailing_html }}</span>
  {%- endif -%}
</{{ element }}>
