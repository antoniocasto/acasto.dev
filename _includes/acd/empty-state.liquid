{%- assign title_tag = include.title_tag | default: 'h3' -%}
<section
  class="{% include acd/_internal/class-name.liquid base='ac-empty-state' extra=include.class %}"
  {%- include acd/_internal/attribute.liquid name='id' value=include.id -%}
  {%- include acd/_internal/data-attr.liquid name='data-ac-size' value=include.size -%}
  {%- if include.attrs %} {{ include.attrs | strip }}{%- endif -%}
>
  {%- if include.icon_html -%}
    <span class="ac-empty-state__icon" aria-hidden="true">{{ include.icon_html }}</span>
  {%- endif -%}
  <div class="ac-empty-state__body">
    <{{ title_tag }} class="ac-empty-state__title">{{ include.title | escape }}</{{ title_tag }}>
    {%- if include.subtitle -%}
      <p class="ac-empty-state__subtitle">{{ include.subtitle | escape }}</p>
    {%- endif -%}
  </div>
  {%- if include.actions_html -%}
    <div class="ac-empty-state__actions">{{ include.actions_html }}</div>
  {%- endif -%}
</section>
